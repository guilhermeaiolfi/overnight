{
    "name": "guilhermeaiolfi/overnight",
    "description": "New ideas for a PHP framework",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "psr/container": "^1.0||^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0.1 || ^2.0.0",
        "psr/http-server-middleware": "^1.0",
        "laminas/laminas-diactoros": "3.x",
        "php-di/php-di": "^7.0",
        "laminas/laminas-stratigility": "^4.0",
        "php-di/invoker": "^2.3",
        "psr/log": "^3.0",
        "monolog/monolog": "^3.7",
        "league/event": "^3.0",
        "symfony/dotenv": "^7.1",
        "symfony/finder": "^7.1",
        "roave/better-reflection": "^6.42",
        "symfony/cache": "^7.1",
        "symfony/console": "^7.1",
        "laminas/laminas-httphandlerrunner": "^2.11",
        "nikic/fast-route": "^1.3",
        "league/plates": "^3.6",
        "spatie/php-structure-discoverer": "^2.2",
        "cycle/orm": "^2.10.1",
        "cycle/migrations": "^4.2",
        "cycle/schema-migrations-generator": "^2.2",
        "cycle/schema-builder": "^2.11",
        "webonyx/graphql-php": "^15.0",
        "laminas/laminas-stdlib": "^3.20",
        "mezzio/mezzio-helpers": "^5.18",
        "somnambulist/validation": "^1.13",
        "guilhermeaiolfi/overnight-data": "1.2.0"
      },
      "require-dev": {
        "itsgoingd/clockwork": "^5.2",
        "phpunit/phpunit": "^11.5",
        "kint-php/kint": "^5.1",
        "filp/whoops": "^2.16",
        "friendsofphp/php-cs-fixer": "^3.64",
        "latte/latte": "^3.1",
        "phpbench/phpbench": "^1.4"
    },
    "autoload-dev": {
      "psr-4": {
        "Tests\\ON\\": "tests/",
        "Benchmarks\\ON\\": "benchmarks/"
      }
    },
    "scripts": {
      "bench": "phpbench run --config=phpbench.json",
      "bench:bootstrap": "phpbench run --config=phpbench.json --filter=BootstrapBench",
      "bench:bootstrap:record": "php benchmark/bootstrap_bench.php record",
      "bench:bootstrap:compare": "php benchmark/bootstrap_bench.php compare"
    },
    "autoload": {
      "psr-4": {
        "ON\\": "src/"
      }
    },
    "repositories": [{
        "name": "overnight-data",
        "type": "vcs",
        "url": "https://github.com/guilhermeaiolfi/overnight-data.git"
    }]
}
